    <diagram id="bupa-it-strategy-architecture-north-star-v3" name="Architecture North Star v3">
        <mxGraphModel dx="1800" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1200" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="page-bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#E5E7EB;strokeWidth=1;" parent="1" vertex="1">
                    <mxGeometry x="30" y="30" width="1740" height="1110" as="geometry"/>
                </mxCell>
                <mxCell id="title" value="&lt;div style=&quot;font-size: 34px; font-weight: 700; color: rgb(17, 24, 39);&quot;&gt;Bupa As One Technology North Star&lt;/div&gt;&lt;div style=&quot;font-size: 17px; color: rgb(55, 65, 81); margin-top: 6px;&quot;&gt;Architectural delivery view: what we must build and what we must do&lt;/div&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
                    <mxGeometry x="70" y="55" width="980" height="72" as="geometry"/>
                </mxCell>
                <mxCell id="north-star" value="&lt;div style=&quot;font-size: 28px; font-weight: 700; color: rgb(255,255,255);&quot;&gt;Build the connected healthcare experience platform&lt;/div&gt;&lt;div style=&quot;font-size: 15px; color: rgb(231,245,255); margin-top: 8px; line-height: 1.35;&quot;&gt;Customers do not restart. Teams build through paved roads. Business units fulfil behind common contracts. People, systems and authorised AI agents can use trusted context.&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#005EB8;strokeColor=#004B93;strokeWidth=2;arcSize=6;" parent="1" vertex="1">
                    <mxGeometry x="70" y="140" width="1660" height="95" as="geometry"/>
                </mxCell>
                <mxCell id="journey-demand" value="&lt;div style=&quot;font-size: 19px; font-weight: 700; color: rgb(12, 74, 110);&quot;&gt;Journey demand that must work as one&lt;/div&gt;&lt;div style=&quot;font-size: 14px; color: rgb(17, 24, 39); margin-top: 8px;&quot;&gt;Purchase and enrol | Activate | Find | Book | Arrive | Visit | Pay | Follow-up | Colleague and clinician workflows | Partner and AI-assisted journeys&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#EAF4FF;strokeColor=#8CC7F0;strokeWidth=2;arcSize=6;" parent="1" vertex="1">
                    <mxGeometry x="70" y="260" width="1660" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="requirements-title" value="Six architectural requirements" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;fillColor=#F3F4F6;strokeColor=#9CA3AF;strokeWidth=1;fontColor=#111827;arcSize=6;" parent="1" vertex="1">
                    <mxGeometry x="70" y="370" width="220" height="48" as="geometry"/>
                </mxCell>
                <mxCell id="req-1" value="&lt;b&gt;1. Single customer and health context&lt;/b&gt;&lt;br&gt;No re-entry. No journey restart." style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=middle;fontSize=13;fillColor=#F0F9FF;strokeColor=#0284C7;strokeWidth=1;fontColor=#0F172A;spacingLeft=12;arcSize=6;" parent="1" vertex="1">
                    <mxGeometry x="70" y="435" width="220" height="66" as="geometry"/>
                </mxCell>
                <mxCell id="req-2" value="&lt;b&gt;2. One truth, many governed copies&lt;/b&gt;&lt;br&gt;Local stores are allowed with lineage." style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=middle;fontSize=13;fillColor=#F0FDFA;strokeColor=#0D9488;strokeWidth=1;fontColor=#0F172A;spacingLeft=12;arcSize=6;" parent="1" vertex="1">
                    <mxGeometry x="70" y="512" width="220" height="66" as="geometry"/>
                </mxCell>
                <mxCell id="req-3" value="&lt;b&gt;3. Contracts before products&lt;/b&gt;&lt;br&gt;Open APIs, events, data contracts and protocols." style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=middle;fontSize=13;fillColor=#EFF6FF;strokeColor=#2563EB;strokeWidth=1;fontColor=#0F172A;spacingLeft=12;arcSize=6;" parent="1" vertex="1">
                    <mxGeometry x="70" y="589" width="220" height="66" as="geometry"/>
                </mxCell>
                <mxCell id="req-4" value="&lt;b&gt;4. Shared services before local rebuild&lt;/b&gt;&lt;br&gt;Reuse or extend enterprise capabilities." style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=middle;fontSize=13;fillColor=#F7FEE7;strokeColor=#65A30D;strokeWidth=1;fontColor=#0F172A;spacingLeft=12;arcSize=6;" parent="1" vertex="1">
                    <mxGeometry x="70" y="666" width="220" height="66" as="geometry"/>
                </mxCell>
                <mxCell id="req-5" value="&lt;b&gt;5. Context-ready data and knowledge&lt;/b&gt;&lt;br&gt;Discoverable, executable and traceable." style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=middle;fontSize=13;fillColor=#FFFBEB;strokeColor=#D97706;strokeWidth=1;fontColor=#0F172A;spacingLeft=12;arcSize=6;" parent="1" vertex="1">
                    <mxGeometry x="70" y="743" width="220" height="66" as="geometry"/>
                </mxCell>
                <mxCell id="req-6" value="&lt;b&gt;6. Paved roads for developers&lt;/b&gt;&lt;br&gt;Fast compliant delivery by default." style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=middle;fontSize=13;fillColor=#F5F3FF;strokeColor=#7C3AED;strokeWidth=1;fontColor=#0F172A;spacingLeft=12;arcSize=6;" parent="1" vertex="1">
                    <mxGeometry x="70" y="820" width="220" height="66" as="geometry"/>
                </mxCell>
                <mxCell id="main-frame" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#CBD5E1;strokeWidth=2;arcSize=4;" parent="1" vertex="1">
                    <mxGeometry x="320" y="370" width="1040" height="580" as="geometry"/>
                </mxCell>
                <mxCell id="architecture-label" value="Target architecture build components" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;fillColor=#111827;strokeColor=#111827;strokeWidth=1;fontColor=#FFFFFF;arcSize=6;" parent="1" vertex="1">
                    <mxGeometry x="680" y="348" width="320" height="42" as="geometry"/>
                </mxCell>
                <mxCell id="experience-composition" value="&lt;div style=&quot;font-size: 21px; font-weight: 700; color: rgb(12, 74, 110);&quot;&gt;Experience and Composition Layer&lt;/div&gt;&lt;div style=&quot;font-size: 13px; color: rgb(17, 24, 39); margin-top: 8px;&quot;&gt;Journey orchestration | Channel APIs | Session continuity | Colleague and clinician workflow composition | No restart by design&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#E0F2FE;strokeColor=#0284C7;strokeWidth=2;arcSize=6;" parent="1" vertex="1">
                    <mxGeometry x="350" y="405" width="980" height="88" as="geometry"/>
                </mxCell>
                <mxCell id="relationship-context" value="&lt;div style=&quot;font-size: 18px; font-weight: 700; color: rgb(15, 118, 110);&quot;&gt;Bupa Relationship Context&lt;/div&gt;&lt;div style=&quot;font-size: 13px; color: rgb(17, 24, 39); margin-top: 8px; line-height: 1.35;&quot;&gt;Identity and party model&lt;br&gt;Profile, consent and preferences&lt;br&gt;Session and interaction history&lt;br&gt;Single customer and health context&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#CCFBF1;strokeColor=#0D9488;strokeWidth=2;arcSize=6;" parent="1" vertex="1">
                    <mxGeometry x="350" y="525" width="300" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="capability-services" value="&lt;div style=&quot;font-size: 18px; font-weight: 700; color: rgb(63, 98, 18);&quot;&gt;Enterprise Capability Services&lt;/div&gt;&lt;div style=&quot;font-size: 13px; color: rgb(17, 24, 39); margin-top: 8px; line-height: 1.35;&quot;&gt;Eligibility | Booking | Payment&lt;br&gt;Claims | Provider | Referral&lt;br&gt;Care navigation | Communications&lt;br&gt;Follow-up and service orchestration&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#ECFCCB;strokeColor=#65A30D;strokeWidth=2;arcSize=6;" parent="1" vertex="1">
                    <mxGeometry x="690" y="525" width="300" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="interop-fabric" value="&lt;div style=&quot;font-size: 18px; font-weight: 700; color: rgb(30, 64, 175);&quot;&gt;Contract-led Interoperability&lt;/div&gt;&lt;div style=&quot;font-size: 13px; color: rgb(17, 24, 39); margin-top: 8px; line-height: 1.35;&quot;&gt;API and event platform&lt;br&gt;Contract and schema registry&lt;br&gt;FHIR-aligned clinical exchange&lt;br&gt;OpenAPI, AsyncAPI and service ACLs&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#DBEAFE;strokeColor=#2563EB;strokeWidth=2;arcSize=6;" parent="1" vertex="1">
                    <mxGeometry x="1030" y="525" width="300" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="data-knowledge" value="&lt;div style=&quot;font-size: 18px; font-weight: 700; color: rgb(146, 64, 14);&quot;&gt;Data and Knowledge Plane&lt;/div&gt;&lt;div style=&quot;font-size: 13px; color: rgb(17, 24, 39); margin-top: 8px; line-height: 1.35;&quot;&gt;Authoritative data products | Semantic layer | Catalogue | Lineage | Quality scoring | Decision intelligence | Policy and operational knowledge&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#FEF3C7;strokeColor=#D97706;strokeWidth=2;arcSize=6;" parent="1" vertex="1">
                    <mxGeometry x="350" y="710" width="470" height="105" as="geometry"/>
                </mxCell>
                <mxCell id="fulfilment-adapters" value="&lt;div style=&quot;font-size: 18px; font-weight: 700; color: rgb(55, 65, 81);&quot;&gt;BU Fulfilment and Ecosystem Adapters&lt;/div&gt;&lt;div style=&quot;font-size: 13px; color: rgb(17, 24, 39); margin-top: 8px; line-height: 1.35;&quot;&gt;Market platforms | Product systems | Legacy cores | Provider networks | Partners | Local databases for optimised execution&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#F3F4F6;strokeColor=#6B7280;strokeWidth=2;arcSize=6;" parent="1" vertex="1">
                    <mxGeometry x="860" y="710" width="470" height="105" as="geometry"/>
                </mxCell>
                <mxCell id="developer-platform" value="&lt;div style=&quot;font-size: 21px; font-weight: 700; color: rgb(76, 29, 149);&quot;&gt;Developer Platform and Bupa Engineering Operating System&lt;/div&gt;&lt;div style=&quot;font-size: 13px; color: rgb(17, 24, 39); margin-top: 8px;&quot;&gt;Developer portal | Golden paths | Service templates | Environments | CI/CD | IAM and secrets | Policy as code | Observability | SLOs | Runtime and cloud controls | FinOps&lt;/div&gt;&lt;div style=&quot;font-size: 13px; color: rgb(76, 29, 149); margin-top: 8px; font-weight: 700;&quot;&gt;Headline measure: Time to HelloWorld&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#EDE9FE;strokeColor=#7C3AED;strokeWidth=2;arcSize=6;" parent="1" vertex="1">
                    <mxGeometry x="350" y="845" width="980" height="85" as="geometry"/>
                </mxCell>
                <mxCell id="actions-title" value="What we must do" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;fillColor=#F3F4F6;strokeColor=#9CA3AF;strokeWidth=1;fontColor=#111827;arcSize=6;" parent="1" vertex="1">
                    <mxGeometry x="1390" y="370" width="340" height="48" as="geometry"/>
                </mxCell>
                <mxCell id="actions" value="&lt;div style=&quot;font-size: 13px; color: rgb(17, 24, 39); line-height: 1.45; text-align: left;&quot;&gt;&lt;b&gt;1. Name capability owners&lt;/b&gt;&lt;br&gt;Fund roadmaps and lifecycle accountability.&lt;br&gt;&lt;br&gt;&lt;b&gt;2. Publish semantic and contract catalogue&lt;/b&gt;&lt;br&gt;Make APIs, events, data products and definitions findable.&lt;br&gt;&lt;br&gt;&lt;b&gt;3. Build the first golden paths&lt;/b&gt;&lt;br&gt;Repository to deployed, secure, observable service.&lt;br&gt;&lt;br&gt;&lt;b&gt;4. Migrate priority journeys&lt;/b&gt;&lt;br&gt;Route purchase, activation, find, book, visit, pay and follow-up through reusable services.&lt;br&gt;&lt;br&gt;&lt;b&gt;5. Reduce point-to-point and duplicate truth&lt;/b&gt;&lt;br&gt;Use policy and funded convergence plans, not aspiration.&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fontSize=13;fillColor=#FFFFFF;strokeColor=#CBD5E1;strokeWidth=1;fontColor=#111827;spacing=14;arcSize=6;" parent="1" vertex="1">
                    <mxGeometry x="1390" y="435" width="340" height="295" as="geometry"/>
                </mxCell>
                <mxCell id="measure-title" value="North Star dashboard" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;fillColor=#111827;strokeColor=#111827;strokeWidth=1;fontColor=#FFFFFF;arcSize=6;" parent="1" vertex="1">
                    <mxGeometry x="1390" y="752" width="340" height="44" as="geometry"/>
                </mxCell>
                <mxCell id="measures" value="&lt;div style=&quot;font-size: 13px; color: rgb(17, 24, 39); line-height: 1.5; text-align: left;&quot;&gt;Time to HelloWorld&lt;br&gt;Journey restart rate&lt;br&gt;API, event and data contract reuse&lt;br&gt;Point-to-point integration count&lt;br&gt;Duplicate source of truth exceptions&lt;br&gt;Data product quality and lineage&lt;br&gt;Service SLOs and resilience evidence&lt;br&gt;Control evidence generated by platform&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fontSize=13;fillColor=#F9FAFB;strokeColor=#CBD5E1;strokeWidth=1;fontColor=#111827;spacing=14;arcSize=6;" parent="1" vertex="1">
                    <mxGeometry x="1390" y="812" width="340" height="138" as="geometry"/>
                </mxCell>
                <mxCell id="guardrails" value="&lt;div style=&quot;font-size: 19px; font-weight: 700; color: rgb(17, 24, 39);&quot;&gt;Opinionated guardrails&lt;/div&gt;&lt;div style=&quot;font-size: 13px; color: rgb(17, 24, 39); margin-top: 8px; line-height: 1.45;&quot;&gt;No new strategic integration without a contract. No duplicate source of truth without an exception. No customer restart caused by Bupa complexity. No product owns the enterprise contract. No team rebuilds common plumbing. No AI or automation without traceable context.&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#FFF7ED;strokeColor=#F97316;strokeWidth=2;arcSize=6;" parent="1" vertex="1">
                    <mxGeometry x="70" y="985" width="1660" height="105" as="geometry"/>
                </mxCell>
