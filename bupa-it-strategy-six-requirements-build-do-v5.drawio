<mxfile host="65bd71144e">
    <diagram id="bupa-it-strategy-six-requirements-build-do-v5" name="Six Requirements Build Change v5">
        <mxGraphModel dx="2292" dy="1263" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1230" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="page-bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#E5E7EB;strokeWidth=1;" parent="1" vertex="1">
                    <mxGeometry x="30" y="30" width="1740" height="1170" as="geometry"/>
                </mxCell>
                <mxCell id="title" value="&lt;div style=&quot;font-size: 34px; font-weight: 700; color: rgb(17, 24, 39);&quot;&gt;Bupa As One: Architecture for a Healthcare Experience Company&lt;/div&gt;&lt;div style=&quot;font-size: 17px; color: rgb(55, 65, 81); margin-top: 6px;&quot;&gt;Use the six principles to discuss priority initiatives: what should we build, and what needs to change?&lt;/div&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
                    <mxGeometry x="70" y="55" width="1250" height="72" as="geometry"/>
                </mxCell>
                <mxCell id="north-star" value="&lt;div style=&quot;font-size: 24px; font-weight: 700; color: rgb(255,255,255);&quot;&gt;North Star: Every Step is a Step Forward&lt;/div&gt;&lt;div style=&quot;font-size: 14px; color: rgb(231,245,255); margin-top: 7px;&quot;&gt;One Bupa experience over many products, markets, systems and fulfilment models. Customers do not restart, re-key, repeat themselves, or navigate Bupa&#39;s internal boundaries.&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#005EB8;strokeColor=#004B93;strokeWidth=2;arcSize=6;" parent="1" vertex="1">
                    <mxGeometry x="70" y="140" width="1660" height="78" as="geometry"/>
                </mxCell>
                <mxCell id="central-label" value="For each initiative: pick the principles it advances, then define Build and Change" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;fillColor=#111827;strokeColor=#111827;strokeWidth=1;fontColor=#FFFFFF;arcSize=6;" parent="1" vertex="1">
                    <mxGeometry x="570" y="236" width="680" height="44" as="geometry"/>
                </mxCell>
                <mxCell id="req-1" value="&lt;div style=&quot;font-size: 20px; font-weight: 700; color: rgb(12, 74, 110); text-align: left;&quot;&gt;1. Single Customer and Health Context&lt;/div&gt;&lt;div style=&quot;font-size: 13px; color: rgb(17, 24, 39); margin-top: 8px; text-align: left;&quot;&gt;&lt;b&gt;As One:&lt;/b&gt; Bupa recognises the customer across journeys.&lt;/div&gt;&lt;hr&gt;&lt;div style=&quot;font-size: 13px; color: rgb(12, 74, 110); text-align: left; line-height: 1.45;&quot;&gt;&lt;b&gt;Questions to explore&lt;/b&gt;&lt;br&gt;What customer or health context would this initiative need to build or reuse?&lt;br&gt;What needs to change so customers do not repeat themselves?&lt;/div&gt;&lt;div style=&quot;font-size: 13px; color: rgb(17, 24, 39); text-align: left; line-height: 1.45; margin-top: 10px;&quot;&gt;&lt;b&gt;Example&lt;/b&gt;&lt;br&gt;Build: My profile data&lt;br&gt;Change: Stop duplicate capture in new builds&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=top;fillColor=#E0F2FE;strokeColor=#0284C7;strokeWidth=2;fontColor=#0F172A;spacing=18;arcSize=6;" parent="1" vertex="1">
                    <mxGeometry x="70" y="300" width="520" height="330" as="geometry"/>
                </mxCell>
                <mxCell id="req-2" value="&lt;div style=&quot;font-size: 20px; font-weight: 700; color: rgb(15, 118, 110); text-align: left;&quot;&gt;2. Single Source of Truth, Governed Copies&lt;/div&gt;&lt;div style=&quot;font-size: 13px; color: rgb(17, 24, 39); margin-top: 8px; text-align: left;&quot;&gt;&lt;b&gt;As One:&lt;/b&gt; Bupa gives consistent answers, even when data is used locally.&lt;/div&gt;&lt;hr&gt;&lt;div style=&quot;font-size: 13px; color: rgb(15, 118, 110); text-align: left; line-height: 1.45;&quot;&gt;&lt;b&gt;Questions to explore&lt;/b&gt;&lt;br&gt;What data should be treated as authoritative for this initiative?&lt;br&gt;What governance or reconciliation needs to change?&lt;/div&gt;&lt;div style=&quot;font-size: 13px; color: rgb(17, 24, 39); text-align: left; line-height: 1.45; margin-top: 10px;&quot;&gt;&lt;b&gt;Example&lt;/b&gt;&lt;br&gt;Build: Data ownership register&lt;br&gt;Change: Assign data owners and stewards&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=top;fillColor=#CCFBF1;strokeColor=#0D9488;strokeWidth=2;fontColor=#0F172A;spacing=18;arcSize=6;" parent="1" vertex="1">
                    <mxGeometry x="640" y="300" width="520" height="330" as="geometry"/>
                </mxCell>
                <mxCell id="req-3" value="&lt;div style=&quot;font-size: 20px; font-weight: 700; color: rgb(30, 64, 175); text-align: left;&quot;&gt;3. Contracts before products&lt;/div&gt;&lt;div style=&quot;font-size: 13px; color: rgb(17, 24, 39); margin-top: 8px; text-align: left;&quot;&gt;&lt;b&gt;As One:&lt;/b&gt; Bupa systems connect without exposing internal hand-offs.&lt;/div&gt;&lt;hr&gt;&lt;div style=&quot;font-size: 13px; color: rgb(30, 64, 175); text-align: left; line-height: 1.45;&quot;&gt;&lt;b&gt;Questions to explore&lt;/b&gt;&lt;br&gt;What contracts would make this initiative easier to integrate and reuse?&lt;br&gt;What delivery practice needs to change around those contracts?&lt;/div&gt;&lt;div style=&quot;font-size: 13px; color: rgb(17, 24, 39); text-align: left; line-height: 1.45; margin-top: 10px;&quot;&gt;&lt;b&gt;Example&lt;/b&gt;&lt;br&gt;Build: API, event and data contract registry&lt;br&gt;Change: Version contracts and test conformance&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=top;fillColor=#DBEAFE;strokeColor=#2563EB;strokeWidth=2;fontColor=#0F172A;spacing=18;arcSize=6;" parent="1" vertex="1">
                    <mxGeometry x="1210" y="300" width="520" height="330" as="geometry"/>
                </mxCell>
                <mxCell id="req-4" value="&lt;div style=&quot;font-size: 20px; font-weight: 700; color: rgb(63, 98, 18); text-align: left;&quot;&gt;4. Shared Capability Services&lt;/div&gt;&lt;div style=&quot;font-size: 13px; color: rgb(17, 24, 39); margin-top: 8px; text-align: left;&quot;&gt;&lt;b&gt;As One:&lt;/b&gt; One experience over different BU fulfilment models.&lt;/div&gt;&lt;hr&gt;&lt;div style=&quot;font-size: 13px; color: rgb(63, 98, 18); text-align: left; line-height: 1.45;&quot;&gt;&lt;b&gt;Questions to explore&lt;/b&gt;&lt;br&gt;What common capability could this initiative use or create once?&lt;br&gt;What ownership or roadmap needs to change to make it shared?&lt;/div&gt;&lt;div style=&quot;font-size: 13px; color: rgb(17, 24, 39); text-align: left; line-height: 1.45; margin-top: 10px;&quot;&gt;&lt;b&gt;Example&lt;/b&gt;&lt;br&gt;Build: Communication and follow-up services&lt;br&gt;Change: Name capability owners and roadmaps&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=top;fillColor=#ECFCCB;strokeColor=#65A30D;strokeWidth=2;fontColor=#0F172A;spacing=18;arcSize=6;" parent="1" vertex="1">
                    <mxGeometry x="70" y="665" width="520" height="330" as="geometry"/>
                </mxCell>
                <mxCell id="req-5" value="&lt;div style=&quot;font-size: 20px; font-weight: 700; color: rgb(146, 64, 14); text-align: left;&quot;&gt;5. Knowledge Layer As One Context&lt;/div&gt;&lt;div style=&quot;font-size: 13px; color: rgb(17, 24, 39); margin-top: 8px; text-align: left;&quot;&gt;&lt;b&gt;As One:&lt;/b&gt; People, systems and agents understand Bupa&#39;s services.&lt;/div&gt;&lt;hr&gt;&lt;div style=&quot;font-size: 13px; color: rgb(146, 64, 14); text-align: left; line-height: 1.45;&quot;&gt;&lt;b&gt;Questions to explore&lt;/b&gt;&lt;br&gt;What shared meaning or knowledge would help this initiative scale?&lt;br&gt;What needs to change so teams describe things consistently?&lt;/div&gt;&lt;div style=&quot;font-size: 13px; color: rgb(17, 24, 39); text-align: left; line-height: 1.45; margin-top: 10px;&quot;&gt;&lt;b&gt;Example&lt;/b&gt;&lt;br&gt;Build: Semantic layer and shared glossary&lt;br&gt;Change: Agree shared meanings for key terms&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=top;fillColor=#FEF3C7;strokeColor=#D97706;strokeWidth=2;fontColor=#0F172A;spacing=18;arcSize=6;" parent="1" vertex="1">
                    <mxGeometry x="640" y="665" width="520" height="330" as="geometry"/>
                </mxCell>
                <mxCell id="req-6" value="&lt;div style=&quot;font-size: 20px; font-weight: 700; color: rgb(76, 29, 149); text-align: left;&quot;&gt;6. Developer Experience and Golden Paths&lt;/div&gt;&lt;div style=&quot;font-size: 13px; color: rgb(17, 24, 39); margin-top: 8px; text-align: left;&quot;&gt;&lt;b&gt;As One:&lt;/b&gt; Teams build joined-up services without rebuilding the basics.&lt;/div&gt;&lt;hr&gt;&lt;div style=&quot;font-size: 13px; color: rgb(76, 29, 149); text-align: left; line-height: 1.45;&quot;&gt;&lt;b&gt;Questions to explore&lt;/b&gt;&lt;br&gt;What would make this initiative easier for teams to build and run?&lt;br&gt;What delivery habit or measure needs to change?&lt;/div&gt;&lt;div style=&quot;font-size: 13px; color: rgb(17, 24, 39); text-align: left; line-height: 1.45; margin-top: 10px;&quot;&gt;&lt;b&gt;Example&lt;/b&gt;&lt;br&gt;Build: Service templates and infrastructure as code&lt;br&gt;Change: Deliver priority golden paths on a lean foundation&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=top;fillColor=#EDE9FE;strokeColor=#7C3AED;strokeWidth=2;fontColor=#0F172A;spacing=18;arcSize=6;" parent="1" vertex="1">
                    <mxGeometry x="1210" y="665" width="520" height="330" as="geometry"/>
                </mxCell>
                <mxCell id="decision-footer" value="&lt;div style=&quot;font-size: 19px; font-weight: 700; color: rgb(17, 24, 39);&quot;&gt;Workshop output&lt;/div&gt;&lt;div style=&quot;font-size: 14px; color: rgb(17, 24, 39); margin-top: 8px;&quot;&gt;For each priority initiative, capture which principles it advances, the linked Build and Change hypotheses, and the owners or open questions needed to take the idea forward.&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#FFF7ED;strokeColor=#F97316;strokeWidth=2;arcSize=6;" parent="1" vertex="1">
                    <mxGeometry x="70" y="1030" width="1660" height="105" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
</mxfile>
