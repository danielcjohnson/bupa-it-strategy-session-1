<mxfile host="65bd71144e">
    <diagram id="bupa-it-strategy-six-requirements-build-do-v4" name="Six Requirements Build Change v4">
        <mxGraphModel dx="2292" dy="1263" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1230" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="page-bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#E5E7EB;strokeWidth=1;" parent="1" vertex="1">
                    <mxGeometry x="30" y="30" width="1740" height="1170" as="geometry"/>
                </mxCell>
                <mxCell id="title" value="&lt;div style=&quot;font-size: 34px; font-weight: 700; color: rgb(17, 24, 39);&quot;&gt;Bupa As One: Architecture for a Healthcare Experience Company&lt;/div&gt;&lt;div style=&quot;font-size: 17px; color: rgb(55, 65, 81); margin-top: 6px;&quot;&gt;Hide Bupa&#39;s complexity behind six architectural requirements: what to build and what to change&lt;/div&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
                    <mxGeometry x="70" y="55" width="1250" height="72" as="geometry"/>
                </mxCell>
                <mxCell id="north-star" value="&lt;div style=&quot;font-size: 24px; font-weight: 700; color: rgb(255,255,255);&quot;&gt;North Star: healthcare experience company&lt;/div&gt;&lt;div style=&quot;font-size: 14px; color: rgb(231,245,255); margin-top: 7px;&quot;&gt;One Bupa experience over many products, markets, systems and fulfilment models. Customers do not restart, re-key, repeat themselves, or navigate Bupa&#39;s internal boundaries.&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#005EB8;strokeColor=#004B93;strokeWidth=2;arcSize=6;" parent="1" vertex="1">
                    <mxGeometry x="70" y="140" width="1660" height="78" as="geometry"/>
                </mxCell>
                <mxCell id="central-label" value="Six architectural requirements that deliver an As One Customer Experience" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;fillColor=#111827;strokeColor=#111827;strokeWidth=1;fontColor=#FFFFFF;arcSize=6;" parent="1" vertex="1">
                    <mxGeometry x="570" y="236" width="680" height="44" as="geometry"/>
                </mxCell>
                <mxCell id="req-1" value="&lt;div style=&quot;font-size: 20px; font-weight: 700; color: rgb(12, 74, 110); text-align: left;&quot;&gt;1. Single Customer and Health Context&lt;/div&gt;&lt;div style=&quot;font-size: 13px; color: rgb(17, 24, 39); margin-top: 8px; text-align: left;&quot;&gt;&lt;b&gt;As One:&lt;/b&gt; Bupa recognises the customer across journeys.&lt;/div&gt;&lt;hr&gt;&lt;div style=&quot;font-size: 13px; color: rgb(12, 74, 110); text-align: left; line-height: 1.45;&quot;&gt;&lt;b&gt;Build&lt;/b&gt;&lt;br&gt;Bupa Customer Relationship As One&lt;br&gt;My profile data&lt;br&gt;My engagement with Bupa&lt;br&gt;My Bupa session&lt;br&gt;My health context&lt;/div&gt;&lt;div style=&quot;font-size: 13px; color: rgb(17, 24, 39); text-align: left; line-height: 1.45; margin-top: 10px;&quot;&gt;&lt;b&gt;Change&lt;/b&gt;&lt;br&gt;Name context owners&lt;br&gt;Create funded owners for reusable customer context services&lt;br&gt;Route priority journeys through shared context&lt;br&gt;Stop duplicate capture in new builds&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=top;fillColor=#E0F2FE;strokeColor=#0284C7;strokeWidth=2;fontColor=#0F172A;spacing=18;arcSize=6;" parent="1" vertex="1">
                    <mxGeometry x="70" y="300" width="520" height="330" as="geometry"/>
                </mxCell>
                <mxCell id="req-2" value="&lt;div style=&quot;font-size: 20px; font-weight: 700; color: rgb(15, 118, 110); text-align: left;&quot;&gt;2. Single Source of Truth, Governed Copies&lt;/div&gt;&lt;div style=&quot;font-size: 13px; color: rgb(17, 24, 39); margin-top: 8px; text-align: left;&quot;&gt;&lt;b&gt;As One:&lt;/b&gt; Bupa gives consistent answers, even when data is used locally.&lt;/div&gt;&lt;hr&gt;&lt;div style=&quot;font-size: 13px; color: rgb(15, 118, 110); text-align: left; line-height: 1.45;&quot;&gt;&lt;b&gt;Build&lt;/b&gt;&lt;br&gt;Authoritative data products&lt;br&gt;Governed local stores and caches&lt;br&gt;Event propagation and reconciliation&lt;br&gt;Lineage, quality and freshness controls&lt;br&gt;Data ownership register&lt;/div&gt;&lt;div style=&quot;font-size: 13px; color: rgb(17, 24, 39); text-align: left; line-height: 1.45; margin-top: 10px;&quot;&gt;&lt;b&gt;Change&lt;/b&gt;&lt;br&gt;Assign data owners and stewards&lt;br&gt;Define freshness and reconciliation rules&lt;br&gt;Require exceptions for duplicate truth&lt;br&gt;Measure accuracy, completeness and reuse&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=top;fillColor=#CCFBF1;strokeColor=#0D9488;strokeWidth=2;fontColor=#0F172A;spacing=18;arcSize=6;" parent="1" vertex="1">
                    <mxGeometry x="640" y="300" width="520" height="330" as="geometry"/>
                </mxCell>
                <mxCell id="req-3" value="&lt;div style=&quot;font-size: 20px; font-weight: 700; color: rgb(30, 64, 175); text-align: left;&quot;&gt;3. Contracts before products&lt;/div&gt;&lt;div style=&quot;font-size: 13px; color: rgb(17, 24, 39); margin-top: 8px; text-align: left;&quot;&gt;&lt;b&gt;As One:&lt;/b&gt; Bupa systems connect without exposing internal hand-offs.&lt;/div&gt;&lt;hr&gt;&lt;div style=&quot;font-size: 13px; color: rgb(30, 64, 175); text-align: left; line-height: 1.45;&quot;&gt;&lt;b&gt;Build&lt;/b&gt;&lt;br&gt;API, event and data contract registry&lt;br&gt;Gateway, event bus and schema registry&lt;br&gt;FHIR-aligned clinical exchange patterns&lt;br&gt;OpenAPI and AsyncAPI standards&lt;br&gt;Partner and BU adapter patterns&lt;/div&gt;&lt;div style=&quot;font-size: 13px; color: rgb(17, 24, 39); text-align: left; line-height: 1.45; margin-top: 10px;&quot;&gt;&lt;b&gt;Change&lt;/b&gt;&lt;br&gt;Mandate contract review before funding&lt;br&gt;Publish examples and lifecycle rules&lt;br&gt;Version contracts and test conformance&lt;br&gt;Stop unmanaged point-to-point integration (tbc - is this an issue?)&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=top;fillColor=#DBEAFE;strokeColor=#2563EB;strokeWidth=2;fontColor=#0F172A;spacing=18;arcSize=6;" parent="1" vertex="1">
                    <mxGeometry x="1210" y="300" width="520" height="330" as="geometry"/>
                </mxCell>
                <mxCell id="req-4" value="&lt;div style=&quot;font-size: 20px; font-weight: 700; color: rgb(63, 98, 18); text-align: left;&quot;&gt;4. Shared Capability Services&lt;/div&gt;&lt;div style=&quot;font-size: 13px; color: rgb(17, 24, 39); margin-top: 8px; text-align: left;&quot;&gt;&lt;b&gt;As One:&lt;/b&gt; One experience over different BU fulfilment models.&lt;/div&gt;&lt;hr&gt;&lt;div style=&quot;font-size: 13px; color: rgb(63, 98, 18); text-align: left; line-height: 1.45;&quot;&gt;&lt;b&gt;Build&lt;/b&gt;&lt;br&gt;Consent, eligibility and entitlement services&lt;br&gt;Booking, provider, referral and care navigation&lt;br&gt;Payment, claims and document exchange&lt;br&gt;Communication and follow-up services&lt;br&gt;BU adapters for Health Network and Data Capture&lt;/div&gt;&lt;div style=&quot;font-size: 13px; color: rgb(17, 24, 39); text-align: left; line-height: 1.45; margin-top: 10px;&quot;&gt;&lt;b&gt;Change&lt;/b&gt;&lt;br&gt;Name capability owners and roadmaps&lt;br&gt;Fund shared service lifecycle management&lt;br&gt;Migrate priority journeys incrementally&lt;br&gt;Retire or contain duplicate local capabilities&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=top;fillColor=#ECFCCB;strokeColor=#65A30D;strokeWidth=2;fontColor=#0F172A;spacing=18;arcSize=6;" parent="1" vertex="1">
                    <mxGeometry x="70" y="665" width="520" height="330" as="geometry"/>
                </mxCell>
                <mxCell id="req-5" value="&lt;div style=&quot;font-size: 20px; font-weight: 700; color: rgb(146, 64, 14); text-align: left;&quot;&gt;5. Knowledge Layer As One Context&lt;/div&gt;&lt;div style=&quot;font-size: 13px; color: rgb(17, 24, 39); margin-top: 8px; text-align: left;&quot;&gt;&lt;b&gt;As One:&lt;/b&gt; People, systems and agents understand Bupa&#39;s services.&lt;/div&gt;&lt;hr&gt;&lt;div style=&quot;font-size: 13px; color: rgb(146, 64, 14); text-align: left; line-height: 1.45;&quot;&gt;&lt;b&gt;Build&lt;/b&gt;&lt;br&gt;Semantic layer and shared glossary&lt;br&gt;Catalogue for systems, organisation and products&lt;br&gt;Clinical, policy and journey context&lt;br&gt;Metadata, examples and usage constraints&lt;br&gt;Decision intelligence feeds&lt;/div&gt;&lt;div style=&quot;font-size: 13px; color: rgb(17, 24, 39); text-align: left; line-height: 1.45; margin-top: 10px;&quot;&gt;&lt;b&gt;Change&lt;/b&gt;&lt;br&gt;Agree shared meanings for key terms&lt;br&gt;Make cataloguing part of delivery&lt;br&gt;Publish machine-consumable descriptions inc. schemas&lt;br&gt;Design for authorised AI and employee augmentation&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=top;fillColor=#FEF3C7;strokeColor=#D97706;strokeWidth=2;fontColor=#0F172A;spacing=18;arcSize=6;" parent="1" vertex="1">
                    <mxGeometry x="640" y="665" width="520" height="330" as="geometry"/>
                </mxCell>
                <mxCell id="req-6" value="&lt;div style=&quot;font-size: 20px; font-weight: 700; color: rgb(76, 29, 149); text-align: left;&quot;&gt;6. Developer Experience and Golden Paths&lt;/div&gt;&lt;div style=&quot;font-size: 13px; color: rgb(17, 24, 39); margin-top: 8px; text-align: left;&quot;&gt;&lt;b&gt;As One:&lt;/b&gt; Teams build joined-up services without rebuilding the basics.&lt;/div&gt;&lt;hr&gt;&lt;div style=&quot;font-size: 13px; color: rgb(76, 29, 149); text-align: left; line-height: 1.45;&quot;&gt;&lt;b&gt;Build&lt;/b&gt;&lt;br&gt;Developer desktop experience&lt;br&gt;Golden paths&lt;br&gt;Service templates and infrastructure as code&lt;br&gt;CI/CD, IAM, secrets and policy as code&lt;br&gt;Observability, SLOs and runbooks&lt;br&gt;Runtime, cloud and FinOps controls&lt;/div&gt;&lt;div style=&quot;font-size: 13px; color: rgb(17, 24, 39); text-align: left; line-height: 1.45; margin-top: 10px;&quot;&gt;&lt;b&gt;Change&lt;/b&gt;&lt;br&gt;Address Developer Desktop issues&lt;br&gt;Deliver priority golden paths on a lean foundation&lt;br&gt;Implement DX strategic target operating model&lt;br&gt;Measure &#39;Time to HelloWorld&#39; end to end&lt;br&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=top;fillColor=#EDE9FE;strokeColor=#7C3AED;strokeWidth=2;fontColor=#0F172A;spacing=18;arcSize=6;" parent="1" vertex="1">
                    <mxGeometry x="1210" y="665" width="520" height="330" as="geometry"/>
                </mxCell>
                <mxCell id="decision-footer" value="&lt;div style=&quot;font-size: 19px; font-weight: 700; color: rgb(17, 24, 39);&quot;&gt;Decision test&lt;/div&gt;&lt;div style=&quot;font-size: 14px; color: rgb(17, 24, 39); margin-top: 8px;&quot;&gt;A strategic initiative should help Bupa serve the customer as one: remove journey restarts, hide internal hand-offs, reuse shared capabilities, use governed data and follow supported delivery paths. Exceptions need an owner and review date.&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#FFF7ED;strokeColor=#F97316;strokeWidth=2;arcSize=6;" parent="1" vertex="1">
                    <mxGeometry x="70" y="1030" width="1660" height="105" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
</mxfile>