<mxfile host="65bd71144e">
    <diagram id="bupa-it-strategy-target-state-h-diagram-v1" name="Target State H Diagram v1">
        <mxGraphModel dx="1800" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1200" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="page-bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#E5E7EB;strokeWidth=1;" parent="1" vertex="1">
                    <mxGeometry x="30" y="30" width="1740" height="1110" as="geometry"/>
                </mxCell>
                <mxCell id="title" value="&lt;div style=&quot;font-size: 34px; font-weight: 700; color: rgb(17, 24, 39);&quot;&gt;Bupa As One Target State Architecture&lt;/div&gt;&lt;div style=&quot;font-size: 17px; color: rgb(55, 65, 81); margin-top: 6px;&quot;&gt;An H-shaped view of the target state: four architecture domains connected by contract-led interoperability&lt;/div&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
                    <mxGeometry x="70" y="55" width="1200" height="72" as="geometry"/>
                </mxCell>
                <mxCell id="north-star" value="&lt;div style=&quot;font-size: 25px; font-weight: 700; color: rgb(255,255,255);&quot;&gt;Target state: one connected healthcare experience over many Bupa fulfilment models&lt;/div&gt;&lt;div style=&quot;font-size: 14px; color: rgb(231,245,255); margin-top: 8px; line-height: 1.35;&quot;&gt;Customers do not restart or re-key. Teams build through paved roads. Local platforms fulfil behind reusable capabilities, trusted context and common contracts.&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#005EB8;strokeColor=#004B93;strokeWidth=2;arcSize=6;" parent="1" vertex="1">
                    <mxGeometry x="70" y="140" width="1660" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="journey-demand" value="&lt;div style=&quot;font-size: 18px; font-weight: 700; color: rgb(12, 74, 110);&quot;&gt;Journey demand&lt;/div&gt;&lt;div style=&quot;font-size: 13px; color: rgb(17, 24, 39); margin-top: 7px;&quot;&gt;Purchase and enrol | Activate | Find | Book | Arrive | Visit | Pay | Follow-up | Colleague, clinician, partner and AI-assisted journeys&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#EAF4FF;strokeColor=#8CC7F0;strokeWidth=2;arcSize=6;" parent="1" vertex="1">
                    <mxGeometry x="70" y="255" width="1660" height="72" as="geometry"/>
                </mxCell>
                <mxCell id="h-frame-label" value="The Target State H" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fontSize=19;fontStyle=1;fillColor=#111827;strokeColor=#111827;strokeWidth=1;fontColor=#FFFFFF;arcSize=6;" parent="1" vertex="1">
                    <mxGeometry x="760" y="350" width="280" height="44" as="geometry"/>
                </mxCell>
                <mxCell id="left-column-bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#CBD5E1;strokeWidth=2;arcSize=4;" parent="1" vertex="1">
                    <mxGeometry x="90" y="390" width="600" height="500" as="geometry"/>
                </mxCell>
                <mxCell id="right-column-bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#CBD5E1;strokeWidth=2;arcSize=4;" parent="1" vertex="1">
                    <mxGeometry x="1110" y="390" width="600" height="500" as="geometry"/>
                </mxCell>
                <mxCell id="bridge-bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EEF2FF;strokeColor=#4F46E5;strokeWidth=3;arcSize=4;" parent="1" vertex="1">
                    <mxGeometry x="580" y="542" width="640" height="196" as="geometry"/>
                </mxCell>
                <mxCell id="area-1" value="&lt;div style=&quot;font-size: 22px; font-weight: 700; color: rgb(12, 74, 110);&quot;&gt;1. Experience and Relationship Context&lt;/div&gt;&lt;div style=&quot;font-size: 13px; color: rgb(17, 24, 39); margin-top: 8px; line-height: 1.4;&quot;&gt;One Bupa front door for customers, colleagues and clinicians. Journey orchestration keeps context across channels and prevents avoidable restarts.&lt;/div&gt;&lt;div style=&quot;font-size: 12px; color: rgb(12, 74, 110); margin-top: 10px; font-weight: 700;&quot;&gt;Requirement 1: Single customer and health context&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#E0F2FE;strokeColor=#0284C7;strokeWidth=2;arcSize=6;spacing=14;" parent="1" vertex="1">
                    <mxGeometry x="120" y="420" width="540" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="area-2" value="&lt;div style=&quot;font-size: 22px; font-weight: 700; color: rgb(63, 98, 18);&quot;&gt;2. Shared Capability Services&lt;/div&gt;&lt;div style=&quot;font-size: 13px; color: rgb(17, 24, 39); margin-top: 8px; line-height: 1.4;&quot;&gt;Reusable enterprise services compose the experience while business units continue to specialise in fulfilment, product and market execution.&lt;/div&gt;&lt;div style=&quot;font-size: 12px; color: rgb(63, 98, 18); margin-top: 10px; font-weight: 700;&quot;&gt;Requirement 4: Shared capability services before local rebuild&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#ECFCCB;strokeColor=#65A30D;strokeWidth=2;arcSize=6;spacing=14;" parent="1" vertex="1">
                    <mxGeometry x="120" y="700" width="540" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="area-3" value="&lt;div style=&quot;font-size: 22px; font-weight: 700; color: rgb(146, 64, 14);&quot;&gt;3. Data and Knowledge Context&lt;/div&gt;&lt;div style=&quot;font-size: 13px; color: rgb(17, 24, 39); margin-top: 8px; line-height: 1.4;&quot;&gt;Authoritative data products, governed local copies and a semantic layer make Bupa context discoverable, understandable and traceable.&lt;/div&gt;&lt;div style=&quot;font-size: 12px; color: rgb(146, 64, 14); margin-top: 10px; font-weight: 700;&quot;&gt;Requirements 2 and 5: One truth, governed copies, knowledge layer&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#FEF3C7;strokeColor=#D97706;strokeWidth=2;arcSize=6;spacing=14;" parent="1" vertex="1">
                    <mxGeometry x="1140" y="420" width="540" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="area-4" value="&lt;div style=&quot;font-size: 22px; font-weight: 700; color: rgb(76, 29, 149);&quot;&gt;4. Engineering Operating System&lt;/div&gt;&lt;div style=&quot;font-size: 13px; color: rgb(17, 24, 39); margin-top: 8px; line-height: 1.4;&quot;&gt;Developer portal, golden paths, templates, environments, policy as code and observability make safe delivery fast and efficient by default.&lt;/div&gt;&lt;div style=&quot;font-size: 12px; color: rgb(76, 29, 149); margin-top: 10px; font-weight: 700;&quot;&gt;Requirement 6: Developer experience and golden paths&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#EDE9FE;strokeColor=#7C3AED;strokeWidth=2;arcSize=6;spacing=14;" parent="1" vertex="1">
                    <mxGeometry x="1140" y="700" width="540" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="bridge-label" value="&lt;div style=&quot;font-size: 24px; font-weight: 700; color: rgb(49, 46, 129);&quot;&gt;Contract-led Interoperability Spine&lt;/div&gt;&lt;div style=&quot;font-size: 14px; color: rgb(17, 24, 39); margin-top: 8px; line-height: 1.35;&quot;&gt;APIs, events, data contracts, service ACLs, clinical exchange patterns and shared semantics connect the four domains without coupling Bupa to internal system boundaries.&lt;/div&gt;&lt;div style=&quot;font-size: 12px; color: rgb(30, 64, 175); margin-top: 10px; font-weight: 700;&quot;&gt;Requirement 3: Contracts before products; protocols before platform lock-in&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#DBEAFE;strokeColor=#2563EB;strokeWidth=2;arcSize=6;spacing=14;" parent="1" vertex="1">
                    <mxGeometry x="615" y="575" width="570" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="left-column-label" value="Experience side: what Bupa exposes and composes" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fontSize=14;fontStyle=1;fillColor=#FFFFFF;strokeColor=#CBD5E1;strokeWidth=1;fontColor=#334155;arcSize=6;" parent="1" vertex="1">
                    <mxGeometry x="220" y="370" width="340" height="34" as="geometry"/>
                </mxCell>
                <mxCell id="right-column-label" value="Platform side: what Bupa knows and how teams build" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fontSize=14;fontStyle=1;fillColor=#FFFFFF;strokeColor=#CBD5E1;strokeWidth=1;fontColor=#334155;arcSize=6;" parent="1" vertex="1">
                    <mxGeometry x="1240" y="370" width="340" height="34" as="geometry"/>
                </mxCell>
                <mxCell id="edge-journey-to-exp" value="" style="endArrow=block;html=1;rounded=1;strokeWidth=2;strokeColor=#64748B;" parent="1" source="journey-demand" target="area-1" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="edge-exp-to-bridge" value="" style="endArrow=block;html=1;rounded=1;strokeWidth=2;strokeColor=#64748B;" parent="1" source="area-1" target="bridge-label" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="edge-cap-to-bridge" value="" style="endArrow=block;html=1;rounded=1;strokeWidth=2;strokeColor=#64748B;" parent="1" source="area-2" target="bridge-label" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="edge-data-to-bridge" value="" style="endArrow=block;html=1;rounded=1;strokeWidth=2;strokeColor=#64748B;" parent="1" source="area-3" target="bridge-label" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="edge-os-to-bridge" value="" style="endArrow=block;html=1;rounded=1;strokeWidth=2;strokeColor=#64748B;" parent="1" source="area-4" target="bridge-label" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="fulfilment" value="&lt;div style=&quot;font-size: 18px; font-weight: 700; color: rgb(55, 65, 81);&quot;&gt;Business unit platforms, product systems, providers, partners and local optimised stores&lt;/div&gt;&lt;div style=&quot;font-size: 13px; color: rgb(17, 24, 39); margin-top: 8px;&quot;&gt;Remain local where they create value; exposed through common contracts, shared context, governed data and reusable capability services.&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#F3F4F6;strokeColor=#6B7280;strokeWidth=2;arcSize=6;" parent="1" vertex="1">
                    <mxGeometry x="220" y="930" width="1360" height="78" as="geometry"/>
                </mxCell>
                <mxCell id="decision-footer" value="&lt;div style=&quot;font-size: 19px; font-weight: 700; color: rgb(17, 24, 39);&quot;&gt;Decision test&lt;/div&gt;&lt;div style=&quot;font-size: 13px; color: rgb(17, 24, 39); margin-top: 8px; line-height: 1.45;&quot;&gt;Does the initiative strengthen one of the four domains and connect through the interoperability spine? If not, it needs a named exception, owner and convergence path. The H should pull local delivery toward Bupa As One rather than creating another isolated platform, data store or customer hand-off.&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#FFF7ED;strokeColor=#F97316;strokeWidth=2;arcSize=6;" parent="1" vertex="1">
                    <mxGeometry x="70" y="1040" width="1660" height="82" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
</mxfile>
